# Database
DATABASE_URL=postgresql://edu:edu@postgres:5432/eduplatform

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=super-secret-key-min-32-chars-change-in-production
JWT_EXPIRES_IN=7d

# Storage
STORAGE_PATH=/app/storage
MAX_FILE_SIZE_MB=50

# CORS
FRONTEND_URL=http://localhost:5173

# Server
PORT=3000
NODE_ENV=development
