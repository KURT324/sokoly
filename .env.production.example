# ============================================================
# EduPlatform — Production Environment Variables
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to version control.
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=edu
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=eduplatform

# Full DATABASE_URL (used by Prisma and backend)
DATABASE_URL=postgresql://edu:CHANGE_ME_STRONG_PASSWORD@postgres:5432/eduplatform

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379

# --- JWT ---
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS

# --- App ---
NODE_ENV=production
PORT=3000

# --- Storage ---
# Absolute path inside the backend container where uploaded files are stored
STORAGE_PATH=/app/storage

# --- Domain (used for CORS and cookie settings) ---
FRONTEND_URL=https://YOUR_DOMAIN,https://www.YOUR_DOMAIN

# --- Cookie ---
# Set to true in production (requires HTTPS)
COOKIE_SECURE=true
COOKIE_DOMAIN=YOUR_DOMAIN
